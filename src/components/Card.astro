---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, titleZh, description, descriptionZh, ...props } = data;
---

<li class="my-6">
  <a
    href={getPath(id, filePath)}
    class:list={[
      "inline-block text-lg font-medium text-accent",
      "decoration-dashed underline-offset-4 hover:underline",
      "focus-visible:no-underline focus-visible:underline-offset-0",
    ]}
  >
    <Heading
      style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
    >
      <span class="lang-en">{title}</span>
      {titleZh && <span class="lang-zh">{titleZh}</span>}
      {!titleZh && <span class="lang-zh">{title}</span>}
    </Heading>
  </a>
  <Datetime {...props} />
  <p>
    <span class="lang-en">{description}</span>
    {descriptionZh && <span class="lang-zh">{descriptionZh}</span>}
    {!descriptionZh && <span class="lang-zh">{description}</span>}
  </p>
</li>
